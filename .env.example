# PostgreSQL — Railway public TCP proxy URL (works for local dev AND remote)
# Get the live value from: https://railway.com/project/ad9b3557-a3c6-4556-96eb-2893f365919e
# Look at the "Postgres" service → Variables → DATABASE_PUBLIC_URL
DATABASE_URL=postgresql://postgres:PASSWORD@interchange.proxy.rlwy.net:57657/railway

# Current PoE2 patch version — gates which patch_version_id rows are read/written
PATCH_VERSION=0.4

NODE_ENV=development

# api service
PORT=3001
CORS_ORIGIN=http://localhost:3000

# web service
NEXT_PUBLIC_API_URL=http://localhost:3001

# ingest service
INGEST_SCHEDULE=0 6 * * *
POB_REPO_PATH=.pob-cache/PathOfBuilding-PoE2
